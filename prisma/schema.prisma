// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 帳號模型 (給 NextAuth 或自訂驗證用)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // Hashed password
  role          Role      @default(USER) // ADMIN or USER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  orders        Order[] // 關聯到訂單
}

enum Role {
  USER
  ADMIN
}

// 遊戲分類
model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[] // 關聯到產品
}

// 產品/輔助工具模型
model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  imageUrl    String?     // 商品封面圖片網址
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  status      String      @default("NORMAL") // e.g. NORMAL, UPDATING, MAINTENANCE
  features    Json?       // 用來儲存商品特色標籤與系統環境
  stock       Int         @default(0) // 新增：商品全域庫存
  pricePlans  PricePlan[] // 價格方案
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 價格與授權時長方案
model PricePlan {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  name         String // e.g. "天卡", "月卡"
  durationDays Int? // 授權天數，null 代表永久
  price        Float
}

// 新增：訂單項目
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  planName    String
  quantity    Int
  price       Float
}

// 訂單模型
model Order {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  totalAmount Float
  status      String      @default("PENDING") // PENDING, COMPLETED(已發貨), CANCELLED
  items       OrderItem[] // 訂單包含的商品項目
  notes       String?     // 管理員發貨備註/序號內容
  discordChannelId String? // 用來儲存 Discord 票務頻道 ID
  createdAt   DateTime    @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

